
create table Manager (
   mgr_id               INTEGER                         not null,
   mgr_first_name       VARCHAR2(30)                    not null,
   mgr_middle_name      VARCHAR2(30)                    not null,
   mgr_last_name        VARCHAR2(30)                    not null,
   constraint PK_MANAGER primary key (mgr_id)
)
/
create table Project (
   prj_id               INTEGER                         not null,
   prj_name             VARCHAR2(50)                    not null,
   prj_start            DATE                            default sysdate not null,
   prj_end              DATE                            default sysdate not null,
   prj_mgr_id           INTEGER,
   constraint PK_PROJECT primary key (prj_id),
   constraint FK_PROJECT_REFERENCE_MANAGER foreign key (prj_mgr_id)
         references Manager (mgr_id),
   constraint prj_date_check check(prj_start <= prj_end)
)
/

create table Task (
   tsk_id               INTEGER                         not null,
   tsk_name             VARCHAR2(50)                    not null,
   tsk_specification    VARCHAR2(255)                   not null,
   tsk_start            DATE                            default sysdate,
   tsk_end              DATE                            default sysdate,
   tsk_percent_complete INTEGER                         default 0 constraint tsk_pcomplete check (tsk_percent_complete between 0 and 100),
   tsk_prj_id           INTEGER,
   constraint PK_TASK primary key (tsk_id),
   constraint FK_TASK_REFERENCE_PROJECT foreign key (tsk_prj_id)
         references Project (prj_id),
   constraint tsk_date_check check(tsk_start <= tsk_end)
)
/

create table Programmer (
   prg_id               INTEGER                         not null,
   prg_first_name       VARCHAR2(30)                    not null,
   prg_middle_name      VARCHAR2(30)                    not null,
   prg_last_name        VARCHAR2(30)                    not null,
   prg_main_skill       VARCHAR2(50)                    not null,
   constraint PK_PROGRAMMER primary key (prg_id)
)
/

create table TaskAssignment (
   ta_tsk_id            INTEGER                         not null,
   ta_prg_id            INTEGER                         not null,
   ta_load_percent      INTEGER                         default 0 constraint ta_lpercent check (ta_load_percent between 0 and 100),
   constraint PK_TASKASSIGNMENT primary key (ta_tsk_id, ta_prg_id),
   constraint FK_TASKASSI_REFERENCE_PROGRAMM foreign key (ta_prg_id)
         references Programmer (prg_id),
   constraint FK_TASKASSI_REFERENCE_TASK foreign key (ta_tsk_id)
         references Task (tsk_id)
)

