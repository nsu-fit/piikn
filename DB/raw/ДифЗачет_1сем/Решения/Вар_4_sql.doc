rem query 3
select min(prj_name) as "Project", 
       min(prj_start) as "Planned Project Start",
       min(prj_end) as "Planned Project End", 
       (min(prj_end) - min(prj_start))*8 || ' h' as "Planned Project Effort",
       sum((tsk_end - tsk_start)*8) || ' h' as "Actual Project Effort"
from Manager, Project, Task
where (mgr_first_name = '╬Ёръґыют' and mgr_middle_name = '═шъюырщ' and mgr_last_name = '╚трэютші') and    
       prj_mgr_id = mgr_id and 
       not exists (select tsk_id from Task where tsk_prj_id = prj_id and not(tsk_percent_complete = 100)) and
       prj_start >= to_date('01.01.2002','DD.MM.YYYY') and 
       prj_end <= to_date('31.12.2002','DD.MM.YYYY') and 
       prj_id = tsk_prj_id
group by prj_id
order by 4 desc
/
ojectPlanned Project StartPlanned Project EndPlanned Project EffortActual Project Effort╤шсшЁ№╧юЁҐры15.07.0218.12.021248 h488 h1 rows ааа
rem query 4
select min(prj_name) as "Project", 
       (min(prj_end) - min(prj_start))*8 || ' h' as "Planned Project Effort",
       min(mgr_last_name) || ' ' || min(mgr_middle_name) || ' ' || min(mgr_first_name) as "Manager",
       count(distinct ta_prg_id) as "Number Of Programmers"
from Manager, Project, Task, TaskAssignment
where prj_mgr_id = mgr_id and 
      prj_id = tsk_prj_id and 
      tsk_id = ta_tsk_id
group by prj_id, mgr_id
order by 1
/
