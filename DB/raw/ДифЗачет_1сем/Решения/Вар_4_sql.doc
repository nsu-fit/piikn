rem query 1
select distinct prg_last_name || ' ' || prg_middle_name || ' ' || prg_first_name  as "Programmer Name"
from Programmer, Manager, Project, Task, TaskAssignment
where (mgr_first_name = 'Петр' and mgr_middle_name = 'Сергеевич' and mgr_last_name = 'Иванов') and    
       prj_mgr_id = mgr_id and 
       prj_id = tsk_prj_id and 
       tsk_id = ta_tsk_id and 
       ta_prg_id = prg_id and 
       prg_main_skill = 'C++'
order by 1
/


rem query 2
select prj_name as "Project", tsk_name as "Task", ta_load_percent || ' %' as "Load"
from Programmer, TaskAssignment, Task, Project  
where (prg_first_name = '╤шфюЁют' and prg_middle_name = '╧ртхы' and prg_last_name = '╤хьхэютші') and    
       tsk_id = ta_tsk_id and 
       ta_prg_id = prg_id and
       to_date('20.12.2002','DD.MM.YYYY') >= tsk_start and 
       to_date('20.12.2002','DD.MM.YYYY') <= tsk_end and 
       prj_id = tsk_prj_id
order by 1 asc, 3 desc, 2 asc/
